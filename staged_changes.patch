+# ─────────────────────────────────────────────────────────────────────────────
+# COUNT VALIDATOR — re-extraction prompt for mismatched Hindi/English counts
+# ─────────────────────────────────────────────────────────────────────────────
+def count_validator_prompt(
+    question_type: str,
+    language: str,
+    q_nums: list[int] | None,
+    expected_count: int,
+    actual_count: int,
+    other_language: str,
+) -> str:
+    """
+    Generates a re-extraction prompt for a specific question type + language
+    when the count doesn't match the other language's count.
+
+    Parameters:
+        question_type:  e.g. "Short Answer"
+        language:       the language being re-validated ("Hindi" or "English")
+        q_nums:         question numbers from Phase 1 structure
+        expected_count: how many questions the OTHER language extracted (the target)
+        actual_count:   how many this language originally extracted (the mismatch)
+        other_language: the other language name ("English" or "Hindi")
+    """
+    ref = _q_ref(q_nums, f"Look for the {question_type} section.")
+    lang = _language_instruction(language)
+    boundary = _boundary_instruction(q_nums, language)
+
+    # Build a type-specific hint for what this question type looks like
+    type_hints = {
+        "Multiple Choice Question": (
+            "Each sub-question with 4 options (i)(ii)(iii)(iv) = ONE row."
+        ),
+        "Fill in the Blanks": (
+            "Each statement containing a blank '______' = ONE row."
+        ),
+        "True and False": (
+            "Each declarative statement to be marked True/False = ONE row."
+        ),
+        "One Word Answer": (
+            "Each sub-question expecting a one-word or one-sentence answer = ONE row."
+        ),
+        "Very Short Answer": (
+            "Each 2-mark question = ONE row. If a question has 'अथवा/OR', "
+            "the original part = 1 row AND the alternative = 1 separate row."
+        ),
+        "Short Answer": (
+            "Each 3-mark question = ONE row. If a question has 'अथवा/OR', "
+            "the original part = 1 row AND the alternative = 1 separate row."
+        ),
+        "Long Answer": (
+            "Each 4-mark question = ONE row. If a question has 'अथवा/OR', "
+            "the original part = 1 row AND the alternative = 1 separate row."
+        ),
+        "Very Long Answer": (
+            "Each 5/6-mark question = ONE row. If a question has 'अथवा/OR', "
+            "the original part = 1 row AND the alternative = 1 separate row."
+        ),
+        "Match the Following": (
+            "Each complete match block (Column A + Column B) = ONE row."
+        ),
+    }
+    type_hint = type_hints.get(question_type, "Each question = ONE row.")
+
+    direction = "fewer" if actual_count < expected_count else "more"
+
+    return f"""⚠️ COUNT VALIDATION RE-EXTRACTION ⚠️
+
+You are re-extracting "{question_type}" questions from an exam paper PDF
+because a count mismatch was detected between Hindi and English.
+
+═══════════════════════════════════════════════════════
+MISMATCH DETAILS
+═══════════════════════════════════════════════════════
+  Question Type     : {question_type}
+  Your language     : {language}
+  Your count        : {actual_count} questions
+  {other_language} count : {expected_count} questions
+  Issue             : {language} has {direction} questions than {other_language}
+
+This is a BILINGUAL paper — both languages should have the SAME number of
+"{question_type}" questions. The {other_language} section extracted
+{expected_count} questions, but {language} extracted only {actual_count}.
+
+═══════════════════════════════════════════════════════
+YOUR TASK
+═══════════════════════════════════════════════════════
+Re-read the PDF CAREFULLY and extract ALL "{question_type}" questions
+for the {language} section. Pay special attention to:
+
+{"  • OR/अथवा alternatives — each side of अथवा/OR is a SEPARATE question row." if question_type in ("Very Short Answer", "Short Answer", "Long Answer", "Very Long Answer") else ""}
+  • Do NOT skip any sub-question or alternative.
+  • Do NOT merge two questions into one row.
+  • Do NOT add questions from a different question type or section.
+  • Count your extracted questions — you should get close to {expected_count}.
+
+TARGET: {ref}
+{lang}
+{boundary}
+
+COUNTING RULE: {type_hint}
+
+{"CRITICAL — अथवा/OR HANDLING:" if question_type in ("Very Short Answer", "Short Answer", "Long Answer", "Very Long Answer") else ""}
+{"  If question N says: 'question A अथवा question B' (or 'question A OR question B')" if question_type in ("Very Short Answer", "Short Answer", "Long Answer", "Very Long Answer") else ""}
+{"  → Extract 'question A' as row 1" if question_type in ("Very Short Answer", "Short Answer", "Long Answer", "Very Long Answer") else ""}
+{"  → Extract 'question B' as row 2 (strip leading अथवा/OR)" if question_type in ("Very Short Answer", "Short Answer", "Long Answer", "Very Long Answer") else ""}
+{"  → This means each question number WITH an OR alternative produces 2 rows." if question_type in ("Very Short Answer", "Short Answer", "Long Answer", "Very Long Answer") else ""}
+
+═══════════════════════════════════════════════════════
+SELF-CHECK BEFORE RETURNING
+═══════════════════════════════════════════════════════
+Before returning your JSON, count the items in your "questions" array.
+  • Expected count: {expected_count} (to match {other_language})
+  • If your count is different, re-read the section and look for missed
+    questions or incorrectly merged rows.
+  • Common errors to fix:
+    1. Missed अथवा/OR alternative (each OR splits into 2 rows)
+    2. Skipped a question because it contained Latin/Devanagari mixed text
+    3. Stopped too early due to section boundary confusion
+    4. Merged sub-parts that should be separate rows
+
+═══════════════════════════════════════════════════════
+OUTPUT FORMAT
+═══════════════════════════════════════════════════════
+Return ONLY this JSON:
+{{
+  "questions": [
+    {{"question": "<full question text>"}}
+  ]
+}}
+
+{LATEX_INSTRUCTION}
+Return ONLY the JSON object with "questions" key."""
+
